# --- Whop ---
# Standard Webhooks signing secret from your Whop webhook config (whsec_<base64>)
WHOP_WEBHOOK_SECRET=whsec_replace_me

# Whop REST API bearer key (used by the reconciler)
WHOP_API_KEY=replace_me

# Optional: scope reconciler to a specific company id
# WHOP_COMPANY_ID=biz_xxx

# Optional override; defaults to https://api.whop.com/api/v1
# WHOP_API_URL=

# JSON map: Whop product id -> Keap product id
# Example: {"prod_abc":555,"prod_xyz":888}
WHOP_PRODUCT_MAP={}

# --- Keap ---
KEAP_API_KEY=replace_me
# Numeric id of the "Whop" payment method created in Keap admin
KEAP_WHOP_PAYMENT_METHOD_ID=0

# --- Reconciler ---
# audit (alert only) | auto (call processPaymentSucceeded for missing payments)
RECONCILE_MODE=audit
RECONCILE_INTERVAL_MIN=15
RECONCILE_LOOKBACK_HOURS=48

# --- Admin endpoints ---
# Bearer token required for /whop/reconcile and /whop/cache
ADMIN_TOKEN=replace_me

# --- Sentry (error tracking + alerting) ---
# DSN from sentry.io project settings. Empty = Sentry disabled (local dev).
SENTRY_DSN=
# Tag attached to every event for filtering between environments
SENTRY_ENVIRONMENT=production

# --- Server ---
PORT=3001
